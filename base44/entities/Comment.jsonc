{
  "name": "Comment",
  "type": "object",
  "properties": {
    "post_id": {
      "type": "string"
    },
    "parent_id": {
      "type": "string",
      "description": "ID of parent comment for threading (null = top-level)"
    },
    "author_email": {
      "type": "string"
    },
    "author_name": {
      "type": "string"
    },
    "body": {
      "type": "string"
    }
  },
  "required": [
    "post_id",
    "body"
  ]
}